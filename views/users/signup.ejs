<% layout("/layouts/boilerplate") %>

<style>
.auth-page {
  min-height: calc(100vh - 80px);
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

@media(max-width: 768px) {
  .auth-page { grid-template-columns: 1fr; }
  .auth-left { display: none; }
}

/* Left image panel */
.auth-left {
  position: relative;
  background: #1a1a2e;
  overflow: hidden;
}

.auth-left img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.75;
}

.auth-left-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 3rem;
}

.auth-left-logo {
  position: absolute;
  top: 2rem;
  left: 2rem;
  font-size: 1.5rem;
  font-weight: 800;
  color: white;
  font-family: 'Syne', sans-serif;
  text-decoration: none;
}

.auth-left-tagline {
  color: white;
  font-size: 2rem;
  font-weight: 800;
  font-family: 'Syne', sans-serif;
  line-height: 1.3;
  margin: 0;
}

/* Right form panel */
.auth-right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem 2rem;
  background: white;
  overflow-y: auto;
}

.auth-form-box {
  width: 100%;
  max-width: 420px;
}

.auth-icon {
  width: 56px;
  height: 56px;
  background: #f7f7f7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1rem;
  color: #717171;
  font-size: 1.4rem;
}

.auth-title {
  text-align: center;
  font-size: 1.6rem;
  font-weight: 800;
  color: #222;
  margin-bottom: 0.25rem;
  font-family: 'Syne', sans-serif;
}

.auth-subtitle {
  text-align: center;
  color: #717171;
  font-size: 0.88rem;
  margin-bottom: 2rem;
}

.auth-input-group {
  margin-bottom: 1rem;
}

.auth-input-group label {
  display: block;
  font-size: 0.82rem;
  font-weight: 600;
  color: #222;
  margin-bottom: 0.4rem;
}

.auth-input-group input {
  width: 100%;
  padding: 0.85rem 1rem;
  border: 1.5px solid #ebebeb;
  border-radius: 10px;
  font-size: 0.9rem;
  font-family: 'DM Sans', sans-serif;
  color: #222;
  transition: border-color 0.2s, box-shadow 0.2s;
  background: #fafafa;
}

.auth-input-group input:focus {
  outline: none;
  border-color: #222;
  background: white;
  box-shadow: 0 0 0 3px rgba(34,34,34,0.06);
}

.auth-input-group input::placeholder {
  color: #aaa;
}

.auth-submit-btn {
  width: 100%;
  padding: 0.95rem;
  background: #fe424d;
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 700;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 0.5rem;
  letter-spacing: 0.01em;
}

.auth-submit-btn:hover {
  background: #d63340;
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(254,66,77,0.3);
}

.auth-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 1.25rem 0;
  color: #aaa;
  font-size: 0.82rem;
}

.auth-divider::before,
.auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #ebebeb;
}

.auth-footer-text {
  text-align: center;
  font-size: 0.88rem;
  color: #717171;
  margin-top: 1.25rem;
}

.auth-footer-text a {
  color: #fe424d;
  font-weight: 600;
  text-decoration: none;
}

.auth-footer-text a:hover {
  text-decoration: underline;
}

.terms-check {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  margin-bottom: 1.25rem;
}

.terms-check input {
  margin-top: 0.15rem;
  accent-color: #fe424d;
}

.terms-check label {
  font-size: 0.82rem;
  color: #717171;
}

.terms-check label a {
  color: #fe424d;
  text-decoration: none;
  font-weight: 500;
}

/* Dark mode */
body.dark-mode .auth-right { background: #0f172a !important; }
body.dark-mode .auth-form-box .auth-title { color: #e2e8f0 !important; }
body.dark-mode .auth-input-group label { color: #e2e8f0 !important; }
body.dark-mode .auth-input-group input { 
  background: #1e293b !important; 
  border-color: #334155 !important; 
  color: #e2e8f0 !important; 
}
body.dark-mode .auth-input-group input:focus { border-color: #e2e8f0 !important; }
body.dark-mode .auth-icon { background: #1e293b !important; color: #94a3b8 !important; }
body.dark-mode .auth-footer-text { color: #94a3b8 !important; }
body.dark-mode .terms-check label { color: #94a3b8 !important; }
</style>

<div class="auth-page">

  <!-- Left Panel -->
  <div class="auth-left">
    <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=800&q=80" alt="Travel">
    <a href="/listings" class="auth-left-logo">✈️ Travellust</a>
    <div class="auth-left-overlay">
      <p class="auth-left-tagline">Away from Home,<br>Yet Feels Like Home</p>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="auth-right">
    <div class="auth-form-box">

      <div class="auth-icon">
        <i class="fa-regular fa-user"></i>
      </div>
      <h2 class="auth-title">Create account</h2>
      <p class="auth-subtitle">Join thousands of travelers on Travellust</p>

      <form action="/signup" method="POST" novalidate>

        <div class="auth-input-group">
          <label for="username">Username</label>
          <input type="text" name="username" id="username" placeholder="Your username" required>
        </div>

        <div class="auth-input-group">
          <label for="email">Email address</label>
          <input type="email" name="email" id="email" placeholder="you@example.com" required>
        </div>

        <div class="auth-input-group">
          <label for="password">Password</label>
          <input type="password" name="password" id="password" placeholder="Create a password" required>
        </div>

        <div class="terms-check">
          <input type="checkbox" id="terms" required>
          <label for="terms">
            I agree to the <a href="#">Terms & Conditions</a> and <a href="#">Privacy Policy</a>
          </label>
        </div>

        <button type="submit" class="auth-submit-btn">SIGN UP</button>

      </form>

      <div class="auth-divider">or</div>

      <div class="auth-footer-text">
        Already have an account? <a href="/login">Log in</a>
      </div>

    </div>
  </div>

</div>
